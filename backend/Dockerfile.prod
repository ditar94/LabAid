FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN groupadd -r labaid && useradd -r -g labaid labaid

COPY . .

RUN chown -R labaid:labaid /app

USER labaid

EXPOSE 8080

CMD ["bash", "-c", "alembic upgrade head && unset DATABASE_URL_MIGRATE && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080} --workers 2"]
